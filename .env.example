# Core
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Auth (Clerk – used for API JWT verification in middleware)
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>
CLERK_AUDIENCE=
SAAS_SERVICE_API_KEY=replace-with-long-random-secret

# Supabase (Postgres + Auth)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SAAS_DEFAULT_WORKSPACE_ID=default
# Public Supabase keys for client-side auth (login / register)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Market providers
BINANCE_API_KEY=
BYBIT_API_KEY=
BITGET_API_KEY=
COINGECKO_API_KEY=
COINGECKO_API_KEY_HEADER=demo
